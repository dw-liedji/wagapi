# wagapi — environment variables
# Copy to .env and adjust for your deployment

# API key for X-API-KEY authentication (change this!)
WAGAPI_API_KEY=ProductionSecretDynamicTunnelAPIKeyCredentialToken

# Data directory for SQLite database (persistent volume mount)
WAGAPI_DATA_DIR=/data2

# WireGuard server private key (set on interface at startup)
WG0_PRIVATE_KEY=UDo7hB6ETJAzono56ojdWsLgaglvCkcahfdyh6nMPGs=

# WireGuard server public key (fallback if kernel read fails)
WG0_PUBLIC_KEY=T+5q+uAVI4uimkD4ci++waVGEbyp12OfoeUUZV/L7Qs=

# WireGuard server endpoint (used in peer configs)
WG0_ENDPOINT=admin.datavite.com:51820

# DNS servers for peer configs
WG0_DNS=1.1.1.1

# Subnet pool for peer IP allocation
SUBNET_POOL=10.9.0.0/16

# WireGuard listen port (set on interface creation)
WG0_LISTEN_PORT=51820

# Uvicorn port (Dokploy sets PORT automatically)
PORT=8001
